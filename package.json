{
  "name": "serviceopera-site",
  "version": "1.5.70",
  "private": true,
  "type": "module",
  "description": "Static site served by Node (Express); operator console uses password + JWT when ADMIN_PASSWORD_HASH is set. Google Places Text Search is admin-only (POST /api/places/search + operator UI) — see PLACES_LEADS.md.",
  "scripts": {
    "sync:version": "node scripts/write-app-version.mjs",
    "prestart": "npm run sync:version",
    "postversion": "npm run sync:version",
    "test:site-appearance": "node scripts/test-site-appearance-persist.mjs",
    "start": "node server.mjs",
    "preview:static": "npx --yes serve@14 . -l tcp://0.0.0.0:3000",
    "dev:next": "next dev",
    "build:next": "next build",
    "start:next": "next start"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.2",
    "next": "^15.3.2",
    "pg": "^8.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "typescript": "^5.8.3"
  }
}
