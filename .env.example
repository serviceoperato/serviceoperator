# Copy to `.env` for local development (never commit real secrets).

# --- Google Places API (New) — Text Search (`POST /api/places/search`) ---
# Create a key in Google Cloud Console with “Places API (New)” enabled.
# Restrict the key: HTTP referrers / IPs as appropriate; never embed in frontend.
GOOGLE_MAPS_API_KEY=

# Minimum milliseconds between outbound calls to `places.googleapis.com` from this Node process.
PLACES_API_MIN_GAP_MS=400

# --- Existing ServiceOpera server vars (optional for Places-only testing) ---
PORT=8080
RESEND_API_KEY=
RESEND_FROM=
ADMIN_EMAIL=
ADMIN_JWT_SECRET=
# Strong random string; required for stable JWTs across restarts and multiple Railway replicas (admin OTP, legacy email links).
PUBLIC_ORIGIN=
DATA_DIR=
# When set, portal users persist in PostgreSQL (portal_users, portal_pending_registrations) instead of JSON under DATA_DIR.
DATABASE_URL=
CLINIC_SELF_REGISTER=
