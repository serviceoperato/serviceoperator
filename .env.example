# Copy to `.env` for local development (never commit real secrets).

# --- Google Places API (New) — Text Search (admin-only) ---
# GOOGLE_MAPS_API_KEY: server-side only (server.mjs). Never ship to browsers or anonymous clients.
# POST /api/places/search requires an admin JWT (same Bearer as /api/admin/*).
# Operator UI: /operator/places-leads.html (opened from admin nav “Places leads”; short-lived ?t= token).
# Create a key in Google Cloud Console with “Places API (New)” enabled; restrict by IP / server as appropriate.
GOOGLE_MAPS_API_KEY=

# Minimum milliseconds between outbound calls to `places.googleapis.com` from this Node process.
PLACES_API_MIN_GAP_MS=400

# --- Voice pipeline Phase 2 (Cursor Composer, local repo — NOT OpenAI) ---
# From https://cursor.com/dashboard — used by scripts/cursor_voice_phase2.mjs (@cursor/sdk)
# CURSOR_API_KEY=
# CURSOR_MODEL_ID=composer-2
# CURSOR_MODEL_THINKING=high

# --- Existing ServiceOpera server vars (optional for Places-only testing) ---
PORT=8080
RESEND_API_KEY=
RESEND_FROM=
ADMIN_EMAIL=
# Optional public inbox for dynamic mailto helpers only; leave unset for form-only contact UX.
# PUBLIC_CONTACT_EMAIL=
# PUBLIC_CONTACT_FORM_URL=/clinics/010/
# scrypt hash salt:hex — same format as portal passwords. Generate: node scripts/hash-admin-password.mjs "your-password"
ADMIN_PASSWORD_HASH=
# Portal login for ADMIN_EMAIL at /login.html (separate from /admin operator console).
# On first deploy: creates portal_users row. If row already exists, set OPERATOR_PORTAL_PASSWORD_SYNC=true to overwrite hash on boot.
OPERATOR_PORTAL_PASSWORD=
OPERATOR_PORTAL_PASSWORD_SYNC=
OPERATOR_PORTAL_REPORT_SLUG=operator
# Portal + admin Bearer JWTs share one HMAC key. Set either name to the same long random value on every host/replica.
PORTAL_JWT_SECRET=
ADMIN_JWT_SECRET=
# Split Railway (custom domain on *-frontend-* without local ADMIN_PASSWORD_HASH): proxy /api/* to the backend.
# Auto-inferred from RAILWAY_SERVICE_NAME *-frontend-* → *-backend-* when unset. Override if names differ:
# SERVICEOPERA_API_UPSTREAM=https://serviceoperato-backend-production.up.railway.app
# Required on Railway: without this, each deploy generates a new key and users must log in again (local dev may omit).
PUBLIC_ORIGIN=https://serviceopera.to
DATA_DIR=
# When set, portal users persist in PostgreSQL (portal_users, portal_pending_registrations) instead of JSON under DATA_DIR.
DATABASE_URL=
CLINIC_SELF_REGISTER=

# --- Client workspace demo portal (cold-outreach fake data) ---
# JSON object: username -> { password, slug, business }. Server-only; never expose in public/ or NEXT_PUBLIC_*.
# Example (single line): DEMO_PORTAL_ACCOUNTS={"demo":{"password":"…","slug":"demo","business":"Demo Property · Thailand"}}
DEMO_PORTAL_ACCOUNTS=

# --- Dental Design Center audit portal (first-time login handoff) ---
# Shown only via GET /api/public/audit-ddc-first-access while the portal user still has
# password_must_change / passwordMustChange. When the portal user exists, the same response
# includes activationUrl (signed ?access= link for one-click sign-in to the report). Omit or
# leave empty to disable the callout.
AUDIT_DDC_EMAIL=
AUDIT_DDC_TEMP_PASSWORD=
# Optional override for scripts/create-audit-demo-user.mjs (defaults to 004).
AUDIT_DDC_REPORT_SLUG=
# Optional: TTL in ms when minting signed magic links (scripts/mint-audit-ddc-magic-link.mjs). Default 7d; mint enforces max 30d.
AUDIT_DDC_MAGIC_TTL_MS=
