# Copy to `.env` for local development (never commit real secrets).

# --- Google Places API (New) — Text Search (`POST /api/places/search`) ---
# Create a key in Google Cloud Console with “Places API (New)” enabled.
# Restrict the key: HTTP referrers / IPs as appropriate; never embed in frontend.
GOOGLE_MAPS_API_KEY=

# Minimum milliseconds between outbound calls to `places.googleapis.com` from this Node process.
PLACES_API_MIN_GAP_MS=400

# --- Existing ServiceOpera server vars (optional for Places-only testing) ---
PORT=8080
RESEND_API_KEY=
RESEND_FROM=
ADMIN_EMAIL=
# scrypt hash salt:hex — same format as portal passwords. Generate: node scripts/hash-admin-password.mjs "your-password"
ADMIN_PASSWORD_HASH=
# Portal + admin Bearer JWTs share one HMAC key. Set either name to the same long random value on every host/replica.
PORTAL_JWT_SECRET=
ADMIN_JWT_SECRET=
# Required on Railway: without this, each deploy generates a new key and users must log in again (local dev may omit).
PUBLIC_ORIGIN=
DATA_DIR=
# When set, portal users persist in PostgreSQL (portal_users, portal_pending_registrations) instead of JSON under DATA_DIR.
DATABASE_URL=
CLINIC_SELF_REGISTER=

# --- Dental Design Center audit portal (first-time login handoff) ---
# Shown only via GET /api/public/audit-ddc-first-access while the portal user still has
# password_must_change / passwordMustChange. Omit or leave empty to disable the callout.
AUDIT_DDC_EMAIL=
AUDIT_DDC_TEMP_PASSWORD=
# Optional override for scripts/create-audit-demo-user.mjs (defaults to dental-design-center-audit).
AUDIT_DDC_REPORT_SLUG=
