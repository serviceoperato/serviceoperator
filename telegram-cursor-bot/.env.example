# BotFather → @BotFather /newbot
TELEGRAM_BOT_TOKEN=

# Cursor Dashboard → API / Cloud Agents (https://cursor.com/dashboard)
CURSOR_API_KEY=

# Directory assoluta del repo su cui l’agente deve lavorare (es. thaifans)
CURSOR_LOCAL_CWD=C:\Users\...\Documents\thaifans

# Solo questi user Telegram possono usare il bot (numeri separati da virgola). Obbligatorio.
ALLOWED_TELEGRAM_IDS=123456789

# Opzionale — modello Cursor SDK (default: composer-2)
# CURSOR_MODEL_ID=composer-2
# Ragionamento Composer 2: high = più lento/approfondito, low = più veloce (SDK param "thinking")
CURSOR_MODEL_THINKING=high
